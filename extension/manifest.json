{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "1.0.0",
  "update_url": "https://one-max-vpn.vercel.app/update.json",
  "default_locale": "ru",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "webRequest",
    "browsingData",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "alarms",
    "notifications"
  ],

  "host_permissions": ["<all_urls>"],

  "declarative_net_request": {
    "rule_resources": [
      { "id": "trackers", "enabled": true, "path": "rules/tracker_rules.json" }
    ]
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://one-max-vpn.vercel.app"
  }
}

{
  "manifest_version": 3,
  "name": "One Max VPN",
  "version": "1.0.0",
  "description": "Privacy VPN and data saver — аналог Samsung Max VPN",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "One Max VPN"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "update_url": "https://one-max-vpn.vercel.app/update.json",
  "_locales": {
    "en": {
      "name": "One Max VPN"
    }
  }
}
